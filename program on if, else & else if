//waptc the option of atm

let bank = prompt("enter an option"); 
let balance = 1000;

if (bank === "balance") {
    alert("The balance amount is " + balance);
    console.log("The balance amount is " + balance);
} else if (bank === "withdraw") {
    let withdrawAmt = Number(prompt("enter the amount to withdraw"));
    if (withdrawAmt > 0 && withdrawAmt <= balance) {
        balance -= withdrawAmt;
        console.log("The amount withdrawn is " + withdrawAmt);
        alert("The amount withdrawn is " + withdrawAmt + ". New balance: " + balance);
    } else {
        alert("Invalid withdraw amount.");
        console.log("Invalid withdraw amount.");
    }
} else if (bank === "deposit") {
    let depositAmt = Number(prompt("Enter the amount to deposit:"));
    if (depositAmt > 0) {
        balance += depositAmt;
        console.log("The amount deposited is " + depositAmt);
        alert("The amount deposited is " + depositAmt + ". New balance: " + balance);
    } else {
        alert("Invalid deposit amount.");
        console.log("Invalid deposit amount.");
    }
} else {
    console.log("Please enter a proper option (balance, withdraw, deposit)");
}


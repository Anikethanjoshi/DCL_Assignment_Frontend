//wapt calculate total amount for the used unit 

let unit = Number(prompt("enter the used unit"))
let totalamt = 0;

if (unit > 0 && unit <= 100) {
	totalamt = unit * 4;
} else if (unit > 100 && unit <= 200) {
	totalamt = 100 * 4 + (unit - 100) * 6;
} else if (unit > 200 && unit <= 400) {
	totalamt = 100 * 4 + 100 * 6 + (unit - 200) * 8;
} else if (unit > 400) {
	totalamt = 100 * 4 + 100 * 6 + 200 * 8 + (unit - 400) * 10;
} else {
	console.log("Please enter a valid unit.");
}

if (totalamt > 0) {
    console.log("The total amount for " + unit + " units is: " + totalamt);
}


# 8️⃣ Reverse a number

```javascript
let num = prompt("Enter number");
let rev = 0;

while(num > 0){
    let rem = num % 10;
    rev = rev * 10 + rem;
    num = Math.floor(num / 10);
}

console.log(rev);
```

---

# 9️⃣ Check palindrome number

```javascript
let num = prompt("Enter number");
let original = num;
let rev = 0;

while(num > 0){
    let rem = num % 10;
    rev = rev * 10 + rem;
    num = Math.floor(num / 10);
}

if(original == rev){
    console.log("Palindrome");
}
else{
    console.log("Not palindrome");
}
```

